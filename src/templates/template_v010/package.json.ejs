{
  "name": "<%= projectName %>",
  "version": "1.0.0",
  "description": "<%= description || 'Production-ready NestJS backend template with JWT authentication, role-based authorization, Prisma ORM, and Docker' %>",
  "author": "<%= author || 'Your Name <your@email.com>' %>",
  "private": false,
  "license": "<%= license || 'MIT' %>",
  "engines": {
    "node": ">=22.14.0"
  },
  "scripts": {
    "clean": "rimraf dist",
    "prebuild": "rimraf dist",
    "build": "nest build",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "test": "jest --testMatch \"<rootDir>/src/**/*.spec.ts\" --noStackTrace --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "npm run test:cov:all",
    "test:cov:unit": "jest --coverage --testMatch \"<rootDir>/src/**/*.spec.ts\" --runInBand",
    "test:cov:e2e": "jest --coverage --testMatch \"<rootDir>/test/**/*.e2e-spec.ts\" --runInBand",
    "test:cov:all": "jest --coverage --runInBand",
    "test:unit": "jest --testMatch \"<rootDir>/src/**/*.spec.ts\" --noStackTrace --runInBand",
    "test:e2e": "jest --testMatch \"<rootDir>/test/**/*.e2e-spec.ts\" --noStackTrace --runInBand",
    "test:all": "npm run test:unit && npm run test:e2e",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:reset": "prisma migrate reset --force",
    "prisma:studio": "prisma studio",
    "scan": "docker scout quickview <%= projectName %>-app",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "docker": "npm run docker:build",
    "docker:up": "docker compose up -d",
    "docker:up:build": "docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build",
    "docker:up:no-build": "docker compose up -d",
    "docker:build": "npm run docker:up",
    "docker:image:build": "docker compose -f docker-compose.yml -f docker-compose.prod.yml build app",
    "docker:rebuild": "docker compose up -d --build --force-recreate",
    "docker:migrate": "docker compose exec -T app npx prisma migrate deploy || npx prisma migrate deploy",
    "docker:logs": "docker compose logs -f app db",
    "docker:ps": "docker compose ps",
    "docker:restart": "docker compose restart app",
    "docker:shell": "docker compose exec app sh",
    "docker:stop": "docker compose stop",
    "docker:down": "docker compose down",
    "docker:down:volumes": "docker compose down -v",
    "docker:clean:project": "docker compose down -v --remove-orphans",
    "docker:clean:builder": "docker builder prune -f",
    "docker:clean:unused": "docker system prune -f",
    "docker:recover": "npm run docker:clean:project && npm run docker:up:no-build",
    "docker:prod:up": "docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build",
    "docker:prod:up:no-build": "docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d",
    "docker:prod:migrate": "docker compose -f docker-compose.yml -f docker-compose.prod.yml exec -T app npx prisma migrate deploy || npx prisma migrate deploy",
    "docker:prod:deploy": "npm run docker:prod:up && npm run docker:prod:migrate",
    "docker:prod:logs": "docker compose -f docker-compose.yml -f docker-compose.prod.yml logs -f app db",
    "docker:prod:down": "docker compose -f docker-compose.yml -f docker-compose.prod.yml down"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.22.0",
    "@types/passport-jwt": "^4.0.1",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "dotenv": "^17.3.1",
    "helmet": "^8.1.0",
    "http-status-codes": "^2.2.0",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.1",
    "rimraf": "^5.0.5",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.17",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.19.37",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "prisma": "^5.22.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
